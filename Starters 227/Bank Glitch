#include <bits/stdc++.h>

using namespace std;

int main() {
    // your code goes here
    ios::sync_with_stdio(false);
    cin.tie(NULL);
    int T;
    cin >> T;
    while (T--) {
        long long A, B, X, Y;
        cin >> A >> B >> X >> Y;
        long long trades = A / X;
        long long result = A + B + trades * (Y - X);
        cout << result << "\n";
    }
    return 0;

}
